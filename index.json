{
  "name": "mcts-td-planner",
  "description": "通用决策引擎 — 模拟人脑'先想清楚再做'的推演式决策机制。基于MCTS(蒙特卡洛树搜索)+TDL(时序差分学习)混合算法，提供多方案独立内部推演与最优决策能力。",
  "version": "1.0.0",
  "author": "ljjluke",
  "repository": {
    "type": "github",
    "url": "https://github.com/ljjluke/mcts-skill"
  },
  "skills": [
    {
      "name": "mcts-td-planner",
      "description": "【通用决策引擎】基于MCTS+TDL混合算法，模拟人脑的推演式决策机制。每个候选方案在内部独立推演完整的因果链，汇总比较后选出最优方案再执行。",
      "trigger": "当任务有多种可行方案需要决策时自动触发",
      "alwaysApply": true,
      "files": [
        "SKILL.md",
        "engine/mcts-core.md",
        "engine/td-learner.md",
        "policies/task-policy.md",
        "policies/code-task-policy.md",
        "references/algorithm-reference.md",
        "memory/mcts-td-value-archive.md"
      ]
    }
  ],
  "install": {
    "method": "settings.json",
    "config": {
      "extraKnownMarketplaces": {
        "mcts-td-planner": {
          "source": {
            "source": "github",
            "repo": "ljjluke/mcts-skill"
          }
        }
      }
    },
    "commands": [
      "/plugin marketplace add ljjluke/mcts-skill"
    ]
  }
}